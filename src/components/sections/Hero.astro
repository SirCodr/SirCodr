---
import type { Locale } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import { buildWhatsAppLink } from '@/data/contact';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const waLink = buildWhatsAppLink({ locale, intent: 'general' });
---

<section style="padding: 5rem 0 3rem; min-height: 90svh; display: flex; align-items: center;">
  <div class="container-prose" style="width: 100%;">
    <div style="display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center;">

      <!-- Text -->
      <div style="animation: var(--animate-fade-up); animation-delay: 0.1s;">
        <p style="font-size: 1rem; color: var(--color-accent); font-weight: 600; margin-bottom: 0.75rem; letter-spacing: 0.05em; text-transform: uppercase;">
          {t('hero.greeting')}
        </p>
        <h1 style="font-size: clamp(2.5rem, 8vw, 4.5rem); font-weight: 800; line-height: 1.05; letter-spacing: -0.03em; color: var(--tx); margin: 0 0 0.5rem;">
          Juan Pablo<br />Restrepo
        </h1>
        <p style="font-size: clamp(1.1rem, 3vw, 1.4rem); font-weight: 600; color: var(--color-accent); margin-bottom: 1.5rem;">
          {t('hero.role')}
        </p>
        <p style="font-size: 1rem; color: var(--tx-muted); max-width: 36rem; line-height: 1.7; margin-bottom: 2rem;">
          {t('hero.pitch')}
        </p>

        <!-- CTAs -->
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
          <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.126.555 4.126 1.522 5.866L.057 23.886a.5.5 0 0 0 .611.65l6.205-1.617A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.896 0-3.674-.508-5.2-1.394l-.374-.22-3.868 1.007 1.031-3.762-.243-.387A9.96 9.96 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
            {t('hero.cta_whatsapp')}
          </a>
          <a href={locale === 'es' ? '/servicios' : '/en/services'} class="btn-ghost">
            {t('hero.cta_services')} →
          </a>
          <a href="/JuanPabloRestrepo_CV.pdf" download class="btn-ghost">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            {t('hero.cta_cv')}
          </a>
        </div>

        <!-- Stats bar -->
        <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--bd);">
          <div>
            <p style="font-size: 1.75rem; font-weight: 800; color: var(--tx); line-height: 1;">4+</p>
            <p style="font-size: 0.8rem; color: var(--tx-muted);">{locale === 'es' ? 'años de experiencia' : 'years experience'}</p>
          </div>
          <div>
            <p style="font-size: 1.75rem; font-weight: 800; color: var(--tx); line-height: 1;">4</p>
            <p style="font-size: 0.8rem; color: var(--tx-muted);">{locale === 'es' ? 'empresas' : 'companies'}</p>
          </div>
          <div>
            <p style="font-size: 1.75rem; font-weight: 800; color: var(--tx); line-height: 1;">B2</p>
            <p style="font-size: 0.8rem; color: var(--tx-muted);">English</p>
          </div>
        </div>
      </div>

      <!-- Avatar -->
      <div style="display: flex; justify-content: center; animation: var(--animate-fade-in); animation-delay: 0.3s;">
        <div style="position: relative; width: 220px; height: 220px;">
          <div style="position: absolute; inset: -4px; border-radius: 50%; background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light)); opacity: 0.3;"></div>
          <img
            src="/photo_avatar.jpg"
            alt="Juan Pablo Restrepo — Frontend Developer"
            width="220"
            height="220"
            loading="eager"
            decoding="async"
            style="border-radius: 50%; width: 220px; height: 220px; object-fit: cover; object-position: top; position: relative; border: 3px solid var(--bg);"
          />
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    section > div > div {
      grid-template-columns: 1fr auto !important;
    }
    section > div > div > div:last-child {
      order: 0;
    }
  }
</style>
