---
interface ResourceItem {
  label: string
  url: string
  type: 'pdf' | 'figma' | 'notion' | 'url' | 'template'
}

interface Props {
  resources: ResourceItem[]
}

const { resources } = Astro.props

const icons: Record<string, string> = {
  pdf: '📄',
  figma: '🎨',
  notion: '📝',
  template: '📋',
  url: '🔗',
}

const labels: Record<string, string> = {
  pdf: 'PDF',
  figma: 'Figma',
  notion: 'Notion',
  template: 'Plantilla',
  url: 'Recurso',
}
---

{resources.length > 0 && (
  <div class="resource-list">
    <h4 class="resources-title">Recursos adicionales</h4>
    <ul>
      {resources.map((r) => (
        <li>
          <a href={r.url} target="_blank" rel="noopener noreferrer" class="resource-link">
            <span class="resource-icon">{icons[r.type]}</span>
            <span class="resource-label">{r.label}</span>
            <span class="resource-type">{labels[r.type]}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
)}

<style>
  .resource-list {
    margin: 2rem 0;
    padding: 1.25rem;
    border: 1px solid var(--bd);
    border-radius: var(--radius-card);
    background: var(--sf2);
  }

  .resources-title {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--tx-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .resource-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.5rem;
    border-radius: 0.375rem;
    text-decoration: none;
    color: var(--tx);
    font-size: 0.875rem;
    transition: background 0.15s ease;
  }

  .resource-link:hover {
    background: var(--bd);
  }

  .resource-icon {
    font-size: 1rem;
    width: 1.25rem;
    text-align: center;
    flex-shrink: 0;
  }

  .resource-label {
    flex: 1;
    min-width: 0;
  }

  .resource-type {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--tx-muted);
    background: var(--bd);
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    flex-shrink: 0;
  }
</style>
