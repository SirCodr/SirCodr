---
interface Props {
  moduleTitle: string
}
const { moduleTitle } = Astro.props
---

<div class="locked-banner" role="alert">
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
  </svg>
  <span>El módulo <strong>{moduleTitle}</strong> no está habilitado en tu cuenta.</span>
  <a href="/comunidad">Ver módulos disponibles →</a>
</div>

<style>
  .locked-banner {
    position: sticky;
    top: 4rem;
    z-index: 40;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, var(--color-accent) 10%, var(--sf));
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    border-radius: 0.5rem;
    font-size: 0.85rem;
    color: var(--tx);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .locked-banner a {
    margin-left: auto;
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  .locked-banner a:hover {
    text-decoration: underline;
  }
</style>
