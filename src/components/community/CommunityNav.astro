---
interface Props {
  /** Indica si el usuario autenticado es administrador */
  isAdmin: boolean
}

const { isAdmin } = Astro.props
---

{isAdmin && (
  <div class="community-admin-bar" role="navigation" aria-label="Admin">
    <div class="admin-bar-inner">
      <span class="admin-badge" aria-hidden="true">⚙</span>
      <span class="admin-label">Panel admin</span>
      <div class="admin-links">
        <a href="/admin" class="admin-link">Dashboard</a>
        <a href="/admin/usuarios" class="admin-link">Usuarios</a>
        <a href="/admin/usuarios/nuevo" class="admin-link admin-link-cta">+ Nuevo usuario</a>
      </div>
    </div>
  </div>
)}

<style>
  .community-admin-bar {
    width: 100%;
    background: color-mix(in srgb, var(--color-accent) 8%, var(--sf));
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 25%, var(--bd));
    padding: 0.5rem 1.5rem;
  }

  .admin-bar-inner {
    max-width: 64rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .admin-badge {
    font-size: 0.85rem;
    opacity: 0.7;
  }

  .admin-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-right: 0.25rem;
  }

  .admin-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .admin-link {
    padding: 0.25rem 0.625rem;
    font-size: 0.775rem;
    font-weight: 600;
    color: var(--tx-muted);
    text-decoration: none;
    border-radius: 0.375rem;
    transition: background 0.15s, color 0.15s;
  }

  .admin-link:hover {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--tx);
  }

  .admin-link-cta {
    color: var(--color-accent);
    font-weight: 700;
    border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
  }

  .admin-link-cta:hover {
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    color: var(--color-accent);
  }
</style>
