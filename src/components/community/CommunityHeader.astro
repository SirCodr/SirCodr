---
import { Show, UserButton } from '@clerk/astro/components'

const path = Astro.url.pathname
---

<header class="comm-header">
  <div class="container-prose">
    <div class="comm-nav">
      <!-- Brand -->
      <a href="/comunidad" class="comm-brand">
        <span class="brand-accent">JPR</span>
        <span class="brand-slash">/</span>
        <span class="brand-name">Comunidad</span>
      </a>

      <!-- Controls -->
      <div class="comm-controls">
        <a href="/" class="back-link" title="Volver al portfolio">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          Portfolio
        </a>

        <!-- Theme toggle -->
        <button id="theme-toggle" aria-label="Cambiar tema" class="theme-btn">
          <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:none;">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
          </svg>
        </button>

        <!-- Auth -->
        <Show when="signed-in">
          <UserButton />
        </Show>
        <Show when="signed-out">
          <a href="/sign-in" class="sign-in-btn">Ingresar</a>
        </Show>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="comm-menu-toggle"
        aria-label="Abrir menú"
        aria-expanded="false"
        class="comm-hamburger"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="comm-mobile-menu" class="comm-mobile-menu" aria-hidden="true">
      <a href="/" class="mobile-mod-link" style="font-size:0.8rem;color:var(--tx-muted);">← Volver al portfolio</a>
      <Show when="signed-out">
        <a href="/sign-in" class="mobile-mod-link" style="color:var(--color-accent);font-weight:700;">Ingresar</a>
      </Show>
    </div>
  </div>
</header>

<style>
  .comm-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--bd);
  }

  .comm-nav {
    display: flex;
    align-items: center;
    height: 3.5rem;
    gap: 1rem;
  }

  /* Brand */
  .comm-brand {
    display: flex;
    align-items: baseline;
    gap: 0.2rem;
    text-decoration: none;
    font-weight: 800;
    font-size: 1rem;
    flex-shrink: 0;
    letter-spacing: -0.02em;
  }

  .brand-accent { color: var(--color-accent); }
  .brand-slash { color: var(--bd); font-weight: 400; margin: 0 0.1rem; }
  .brand-name { color: var(--tx); }

  /* Controls */
  .comm-controls {
    display: none;
    align-items: center;
    gap: 0.625rem;
    margin-left: auto;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--tx-muted);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    border: 1px solid var(--bd);
    transition: color 0.15s, border-color 0.15s;
  }

  .back-link:hover {
    color: var(--tx);
    border-color: color-mix(in srgb, var(--tx) 30%, transparent);
  }

  .theme-btn {
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    border: 1px solid var(--bd);
    background: transparent;
    cursor: pointer;
    color: var(--tx);
    transition: border-color 0.2s;
  }

  .theme-btn:hover { border-color: color-mix(in srgb, var(--tx) 30%, transparent); }

  .sign-in-btn {
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    color: white;
    background: var(--color-accent);
    padding: 0.3rem 0.75rem;
    border-radius: 0.375rem;
    transition: opacity 0.2s;
  }

  .sign-in-btn:hover { opacity: 0.85; }

  /* Hamburger */
  .comm-hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    margin-left: auto;
    border-radius: 0.5rem;
    border: 1px solid var(--bd);
    background: transparent;
    cursor: pointer;
    color: var(--tx);
  }

  /* Mobile menu */
  .comm-mobile-menu {
    display: none;
    flex-direction: column;
    padding-bottom: 0.75rem;
    gap: 0.125rem;
  }

  .comm-mobile-menu[aria-hidden="false"] { display: flex; }

  .mobile-mod-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.25rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--tx);
    text-decoration: none;
    border-bottom: 1px solid var(--bd);
  }

  .mobile-mod-link.active { color: var(--color-accent); font-weight: 700; }

  .mobile-divider {
    height: 1px;
    background: var(--bd);
    margin: 0.25rem 0;
  }

  /* Desktop breakpoint */
  @media (min-width: 768px) {
    .comm-controls { display: flex; }
    .comm-hamburger { display: none; }
  }
</style>

<script>
  // Theme toggle
  const btn = document.getElementById('theme-toggle')
  const iconSun = document.getElementById('icon-sun')
  const iconMoon = document.getElementById('icon-moon')

  function updateIcons() {
    const isDark = document.documentElement.classList.contains('dark')
    if (iconSun) iconSun.style.display = isDark ? 'block' : 'none'
    if (iconMoon) iconMoon.style.display = isDark ? 'none' : 'block'
  }

  updateIcons()

  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark')
    localStorage.setItem('theme', isDark ? 'dark' : 'light')
    updateIcons()
  })

  // Mobile menu
  const menuBtn = document.getElementById('comm-menu-toggle')
  const mobileMenu = document.getElementById('comm-mobile-menu')

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.getAttribute('aria-hidden') === 'false'
    mobileMenu?.setAttribute('aria-hidden', isOpen ? 'true' : 'false')
    menuBtn.setAttribute('aria-expanded', isOpen ? 'false' : 'true')
  })
</script>
