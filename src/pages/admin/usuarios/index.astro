---
import AdminLayout from '@/layouts/AdminLayout.astro'
import { listStudents } from '@/lib/clerk-admin'

const query = Astro.url.searchParams.get('q') ?? ''
const page = parseInt(Astro.url.searchParams.get('p') ?? '1')
const limit = 20
const offset = (page - 1) * limit

const result = await listStudents({ limit, offset, query: query || undefined })
const users = result.data
const total = result.totalCount ?? users.length
const totalPages = Math.ceil(total / limit)

type UserRow = {
  id: string
  name: string
  email: string
  modules: string[]
  locked: boolean
  hasImage: boolean
  imageUrl: string
  createdAt: string
}

const userRows: UserRow[] = users.map((user) => {
  const meta = (user.publicMetadata ?? {}) as { unlockedModules?: string[] }
  return {
    id: user.id,
    name: [user.firstName, user.lastName].filter(Boolean).join(' ') || '—',
    email: user.emailAddresses[0]?.emailAddress ?? '—',
    modules: Array.isArray(meta.unlockedModules) ? (meta.unlockedModules as string[]) : [],
    locked: !!user.locked,
    hasImage: user.hasImage,
    imageUrl: user.imageUrl,
    createdAt: new Date(user.createdAt).toLocaleDateString('es-CO', { day: '2-digit', month: 'short', year: 'numeric' }),
  }
})
---

<AdminLayout title="Usuarios" activeSection="usuarios">
  <div class="page-header">
    <h1 class="page-title">Usuarios <span class="count-badge">{total}</span></h1>
    <a href="/admin/usuarios/nuevo" class="btn-primary">+ Nuevo usuario</a>
  </div>

  <!-- Search -->
  <form method="get" class="search-form">
    <input
      type="search"
      name="q"
      value={query}
      placeholder="Buscar por nombre o email..."
      class="search-input"
      aria-label="Buscar usuarios"
    />
    <button type="submit" class="search-btn">Buscar</button>
    {query && <a href="/admin/usuarios" class="clear-link">Limpiar</a>}
  </form>

  <!-- Tabla -->
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Usuario</th>
          <th>Módulos desbloqueados</th>
          <th>Estado</th>
          <th>Creado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        {users.length === 0 && (
          <tr>
            <td colspan="5" style="text-align:center;color:var(--tx-muted);padding:2rem;">
              {query ? 'Sin resultados para la búsqueda.' : 'No hay usuarios todavía.'}
            </td>
          </tr>
        )}
        {userRows.map((user) => (
            <tr>
              <td>
                <div class="user-cell">
                  {user.hasImage && <img src={user.imageUrl} width="30" height="30" alt="" class="avatar" />}
                  <div>
                    <div class="user-name">{user.name}</div>
                    <div class="user-email">{user.email}</div>
                  </div>
                </div>
              </td>
              <td>
                <div class="modules-chips">
                  {user.modules.length === 0
                    ? <span class="chip-none">Sin módulos</span>
                    : user.modules.map((m) => <span class="chip-mod">{m}</span>)
                  }
                </div>
              </td>
              <td>
                {user.locked
                  ? <span class="badge-inactive">Inactivo</span>
                  : <span class="badge-active">Activo</span>
                }
              </td>
              <td class="date-cell">{user.createdAt}</td>
              <td>
                <a href={`/admin/usuarios/${user.id}`} class="action-link">Editar</a>
              </td>
            </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Paginación -->
  {totalPages > 1 && (
    <div class="pagination">
      {page > 1 && (
        <a href={`/admin/usuarios?p=${page - 1}${query ? `&q=${encodeURIComponent(query)}` : ''}`} class="page-btn">← Anterior</a>
      )}
      <span class="page-info">Página {page} de {totalPages}</span>
      {page < totalPages && (
        <a href={`/admin/usuarios?p=${page + 1}${query ? `&q=${encodeURIComponent(query)}` : ''}`} class="page-btn">Siguiente →</a>
      )}
    </div>
  )}
</AdminLayout>

<style>
  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .page-title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--tx);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .count-badge {
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    background: var(--sf2);
    border: 1px solid var(--bd);
    border-radius: 999px;
    color: var(--tx-muted);
  }

  .btn-primary {
    padding: 0.6rem 1.25rem;
    background: var(--color-accent);
    color: white;
    border-radius: 0.5rem;
    font-weight: 700;
    font-size: 0.875rem;
    text-decoration: none;
    transition: opacity 0.15s;
    white-space: nowrap;
  }
  .btn-primary:hover { opacity: 0.9; }

  .search-form {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .search-input {
    flex: 1;
    min-width: 12rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--bd);
    border-radius: 0.375rem;
    background: var(--sf);
    color: var(--tx);
    font-size: 0.875rem;
    font-family: inherit;
  }

  .search-input:focus { outline: 2px solid var(--color-accent); outline-offset: 2px; }

  .search-btn {
    padding: 0.55rem 1rem;
    background: var(--sf2);
    border: 1px solid var(--bd);
    border-radius: 0.375rem;
    cursor: pointer;
    font-size: 0.875rem;
    font-family: inherit;
    color: var(--tx);
    transition: background 0.15s;
  }
  .search-btn:hover { background: var(--bd); }

  .clear-link {
    font-size: 0.8rem;
    color: var(--tx-muted);
    text-decoration: none;
  }
  .clear-link:hover { color: var(--tx); }

  .table-wrap {
    background: var(--sf);
    border: 1px solid var(--bd);
    border-radius: var(--radius-card);
    overflow: hidden;
    overflow-x: auto;
  }

  table { width: 100%; border-collapse: collapse; font-size: 0.875rem; min-width: 40rem; }

  th {
    background: var(--sf2);
    padding: 0.6rem 1rem;
    text-align: left;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--tx-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid var(--bd);
  }

  td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--bd);
    color: var(--tx);
    vertical-align: middle;
  }

  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--sf2); }

  .user-cell {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .avatar {
    border-radius: 50%;
    flex-shrink: 0;
  }

  .user-name { font-weight: 600; font-size: 0.875rem; }
  .user-email { font-size: 0.72rem; color: var(--tx-muted); }

  .modules-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .chip-mod {
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.1rem 0.4rem;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    border-radius: 999px;
  }

  .chip-none {
    font-size: 0.72rem;
    color: var(--tx-muted);
  }

  .badge-active {
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, #059669 15%, transparent);
    color: #059669;
  }

  .badge-inactive {
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, #DC2626 12%, transparent);
    color: #DC2626;
  }

  .date-cell { color: var(--tx-muted); font-size: 0.78rem; }

  .action-link {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.8rem;
    text-decoration: none;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.5rem;
    font-size: 0.875rem;
  }

  .page-btn {
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .page-info { color: var(--tx-muted); }
</style>
