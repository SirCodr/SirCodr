---
import AdminLayout from '@/layouts/AdminLayout.astro'
import { getStudentById } from '@/lib/clerk-admin'
import { MODULES } from '@/data/modules'

const { id } = Astro.params
if (!id) return Astro.redirect('/admin/usuarios')

const user = await getStudentById(id).catch(() => null)
if (!user) return Astro.redirect('/admin/usuarios')

const meta = (user.publicMetadata ?? {}) as Record<string, unknown>
const currentModules = Array.isArray(meta.unlockedModules) ? meta.unlockedModules as string[] : []
const notes = typeof meta.notes === 'string' ? meta.notes : ''
const name = [user.firstName, user.lastName].filter(Boolean).join(' ') || '—'
const email = user.emailAddresses[0]?.emailAddress ?? '—'
const createdAt = new Date(user.createdAt).toLocaleDateString('es-CO', { day: '2-digit', month: 'long', year: 'numeric' })
---

<AdminLayout title={`Editar: ${name}`} activeSection="usuarios">
  <div class="page-header">
    <a href="/admin/usuarios" class="back-link">← Volver a usuarios</a>
    <h1 class="page-title">{name}</h1>
  </div>

  <div id="toast" class="toast" aria-live="polite" style="display:none;"></div>

  <div class="user-layout">
    <!-- Info card -->
    <aside class="info-card">
      {user.hasImage && (
        <img src={user.imageUrl} width="64" height="64" alt="" class="avatar" />
      )}
      <div class="info-name">{name}</div>
      <div class="info-email">{email}</div>
      <div class="info-date">Cliente desde {createdAt}</div>
      <div class="info-status">
        {user.locked
          ? <span class="badge-inactive">Inactivo</span>
          : <span class="badge-active">Activo</span>
        }
      </div>

      <hr class="divider" />

      <!-- Acciones -->
      <div class="actions">
        {user.locked ? (
          <button class="action-btn action-enable" data-action="enable" data-id={id}>
            ✓ Activar cuenta
          </button>
        ) : (
          <button class="action-btn action-disable" data-action="disable" data-id={id}>
            🚫 Desactivar cuenta
          </button>
        )}
        <button class="action-btn action-invite" data-action="reinvite" data-id={id} data-email={email} data-name={user.firstName ?? ''}>
          📩 Regenerar bienvenida
        </button>
      </div>
    </aside>

    <!-- Edit form -->
    <div class="edit-section">
      <form id="edit-form" novalidate>
        <input type="hidden" name="userId" value={id} />

        <!-- Módulos -->
        <section class="form-section">
          <h2 class="section-title">Módulos desbloqueados</h2>
          <div class="modules-grid">
            {MODULES.map((mod) => (
              <label class="module-toggle">
                <input
                  type="checkbox"
                  name="modules"
                  value={mod.id}
                  class="toggle-check"
                  checked={currentModules.includes(mod.id)}
                />
                <div class="toggle-card">
                  <span class="mod-icon">{mod.icon}</span>
                  <div>
                    <div class="mod-title">{mod.title}</div>
                    <div class="mod-id">{mod.id}</div>
                  </div>
                </div>
              </label>
            ))}
          </div>
        </section>

        <!-- Notas -->
        <section class="form-section">
          <h2 class="section-title">Notas internas</h2>
          <textarea id="notes" name="notes" class="textarea" rows="4"
            placeholder="Ej: Pagó asesoría LinkedIn en junio 2026. Meta: trabajo remoto USA. Nivel inglés B1."
          >{notes}</textarea>
          <p class="hint">Solo visible en el panel de administrador.</p>
        </section>

        <div class="form-actions">
          <button type="submit" id="save-btn" class="btn-save">Guardar cambios</button>
        </div>
      </form>

      <!-- Mensaje de bienvenida regenerado -->
      <div id="invite-msg" style="display:none;" class="invite-msg">
        <h3>Mensaje de bienvenida</h3>
        <div id="invite-text" class="wa-preview"></div>
        <button id="copy-invite" class="btn-copy">Copiar mensaje</button>
      </div>
    </div>
  </div>
</AdminLayout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .back-link { font-size: 0.8rem; color: var(--tx-muted); text-decoration: none; }
  .back-link:hover { color: var(--tx); }
  .page-title { margin: 0.5rem 0 0; font-size: 1.4rem; font-weight: 800; }

  .toast {
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .toast.error { background: color-mix(in srgb, #DC2626 12%, transparent); color: #DC2626; border: 1px solid color-mix(in srgb, #DC2626 30%, transparent); }
  .toast.success { background: color-mix(in srgb, #059669 12%, transparent); color: #059669; border: 1px solid color-mix(in srgb, #059669 30%, transparent); }

  .user-layout {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .info-card {
    background: var(--sf);
    border: 1px solid var(--bd);
    border-radius: var(--radius-card);
    padding: 1.25rem;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.35rem;
    position: sticky;
    top: 1rem;
  }

  .avatar { border-radius: 50%; margin-bottom: 0.5rem; }
  .info-name { font-weight: 700; font-size: 0.95rem; }
  .info-email { font-size: 0.75rem; color: var(--tx-muted); word-break: break-all; }
  .info-date { font-size: 0.72rem; color: var(--tx-muted); }

  .badge-active {
    font-size: 0.72rem; font-weight: 700; padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, #059669 15%, transparent);
    color: #059669;
  }

  .badge-inactive {
    font-size: 0.72rem; font-weight: 700; padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, #DC2626 12%, transparent);
    color: #DC2626;
  }

  .divider { border: none; border-top: 1px solid var(--bd); width: 100%; margin: 0.5rem 0; }

  .actions { display: flex; flex-direction: column; gap: 0.4rem; width: 100%; }

  .action-btn {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--bd);
    border-radius: 0.375rem;
    background: var(--sf2);
    color: var(--tx);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s;
    text-align: left;
  }

  .action-btn:hover { background: var(--bd); }
  .action-disable { color: #DC2626; }
  .action-enable { color: #059669; }

  .edit-section { display: flex; flex-direction: column; gap: 1.25rem; }

  .form-section {
    background: var(--sf);
    border: 1px solid var(--bd);
    border-radius: var(--radius-card);
    padding: 1.25rem;
    box-shadow: var(--shadow-card);
  }

  .section-title {
    margin: 0 0 1rem;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--tx);
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
    gap: 0.5rem;
  }

  .module-toggle { cursor: pointer; }
  .toggle-check { position: absolute; opacity: 0; width: 0; height: 0; }

  .toggle-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.75rem;
    border: 1.5px solid var(--bd);
    border-radius: 0.5rem;
    background: var(--sf2);
    transition: border-color 0.15s, background 0.15s;
  }

  .toggle-check:checked + .toggle-card {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 8%, var(--sf2));
  }

  .mod-icon { font-size: 1rem; }
  .mod-title { font-size: 0.78rem; font-weight: 700; }
  .mod-id { font-size: 0.68rem; color: var(--tx-muted); }

  .textarea {
    width: 100%;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--bd);
    border-radius: 0.375rem;
    background: var(--sf2);
    color: var(--tx);
    font-size: 0.875rem;
    font-family: inherit;
    resize: vertical;
    transition: border-color 0.15s;
  }

  .textarea:focus { outline: 2px solid var(--color-accent); outline-offset: 2px; }

  .hint { margin: 0.35rem 0 0; font-size: 0.75rem; color: var(--tx-muted); }

  .form-actions { margin-top: 1rem; display: flex; justify-content: flex-end; }

  .btn-save {
    padding: 0.65rem 1.5rem;
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: 0.5rem;
    font-weight: 700;
    font-size: 0.875rem;
    cursor: pointer;
    font-family: inherit;
    transition: opacity 0.15s;
  }

  .btn-save:disabled { opacity: 0.6; cursor: not-allowed; }
  .btn-save:not(:disabled):hover { opacity: 0.9; }

  .invite-msg {
    background: var(--sf);
    border: 1px solid var(--bd);
    border-radius: var(--radius-card);
    padding: 1.25rem;
  }

  .invite-msg h3 { margin: 0 0 0.75rem; font-size: 0.95rem; font-weight: 700; }

  .wa-preview {
    background: var(--sf2);
    border: 1px solid var(--bd);
    border-radius: 0.5rem;
    padding: 1rem;
    font-size: 0.82rem;
    white-space: pre-wrap;
    line-height: 1.6;
    margin-bottom: 0.75rem;
    color: var(--tx);
  }

  .btn-copy {
    padding: 0.55rem 1rem;
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: 0.375rem;
    font-weight: 700;
    font-size: 0.82rem;
    cursor: pointer;
    font-family: inherit;
  }

  @media (max-width: 640px) {
    .user-layout { grid-template-columns: 1fr; }
    .info-card { position: static; }
  }
</style>

<script>
  const toast = document.getElementById('toast') as HTMLElement | null
  const form = document.getElementById('edit-form') as HTMLFormElement | null
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement | null
  const inviteMsg = document.getElementById('invite-msg') as HTMLElement | null
  const inviteText = document.getElementById('invite-text') as HTMLElement | null
  const copyInvite = document.getElementById('copy-invite') as HTMLButtonElement | null

  function showToast(message: string, type: 'error' | 'success') {
    if (!toast) return
    toast.textContent = message
    toast.className = `toast ${type}`
    toast.style.display = 'block'
    setTimeout(() => { if (toast) toast.style.display = 'none' }, 4000)
  }

  // Save modules + notes
  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!saveBtn) return

    const fd = new FormData(form!)
    const userId = fd.get('userId') as string
    const modules = fd.getAll('modules') as string[]
    const notes = fd.get('notes') as string

    saveBtn.disabled = true
    saveBtn.textContent = 'Guardando...'

    try {
      const res = await fetch(`/api/admin/users/${userId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ unlockedModules: modules, notes }),
      })

      if (res.ok) {
        showToast('Cambios guardados correctamente.', 'success')
      } else {
        const data = await res.json()
        showToast(data.error ?? 'Error al guardar.', 'error')
      }
    } catch {
      showToast('Error de conexión.', 'error')
    } finally {
      saveBtn.disabled = false
      saveBtn.textContent = 'Guardar cambios'
    }
  })

  // Action buttons (disable / enable / reinvite)
  document.querySelectorAll<HTMLButtonElement>('[data-action]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const action = btn.dataset.action!
      const id = btn.dataset.id!

      if (action === 'disable' && !confirm('¿Seguro que quieres desactivar esta cuenta?')) return

      btn.disabled = true

      if (action === 'reinvite') {
        const email = btn.dataset.email!
        const firstName = btn.dataset.name!
        const message = `¡Hola ${firstName}! 👋\n\nAquí está el enlace para acceder a la Comunidad JPR:\n\n🔗 https://jotadev-portfolio.vercel.app/comunidad\n\n1. Haz clic en "Ingresar"\n2. Usa tu cuenta: ${email}\n3. Listo — verás tus recursos disponibles\n\n¡Cualquier duda me escribes por aquí! 💪`
        if (inviteText) inviteText.textContent = message
        if (inviteMsg) inviteMsg.style.display = 'block'
        inviteMsg?.scrollIntoView({ behavior: 'smooth', block: 'start' })
        btn.disabled = false
        return
      }

      try {
        const res = await fetch(`/api/admin/users/${id}/${action}`, { method: 'POST' })
        if (res.ok) {
          showToast(action === 'disable' ? 'Cuenta desactivada.' : 'Cuenta activada.', 'success')
          setTimeout(() => window.location.reload(), 1500)
        } else {
          showToast('Error al ejecutar la acción.', 'error')
          btn.disabled = false
        }
      } catch {
        showToast('Error de conexión.', 'error')
        btn.disabled = false
      }
    })
  })

  copyInvite?.addEventListener('click', async () => {
    const text = inviteText?.textContent ?? ''
    try {
      await navigator.clipboard.writeText(text)
      if (copyInvite) {
        copyInvite.textContent = '¡Copiado! ✓'
        setTimeout(() => { if (copyInvite) copyInvite.textContent = 'Copiar mensaje' }, 2000)
      }
    } catch {
      showToast('Selecciona el texto manualmente.', 'error')
    }
  })
</script>
