---
import BaseLayout from '@/layouts/BaseLayout.astro'

const { userId } = Astro.locals.auth()
if (userId) return Astro.redirect('/comunidad')

const locale = 'es' as const
---

<BaseLayout
  title="Ingresar — JPR Comunidad"
  description="Accede a la comunidad de recursos de carrera remota."
  locale={locale}
>
  <meta name="robots" content="noindex,nofollow" slot="head" />
  <div class="signin-page">
    <div class="signin-card">
      <!-- Branding -->
      <div class="signin-brand">
        <span class="brand-logo">JPR<span class="brand-dot">.</span></span>
      </div>
      <h1 class="signin-title">Comunidad JPR</h1>
      <p class="signin-subtitle">
        Ingresa con el correo con el que fuiste invitado.
      </p>

      <!-- Step 1: email -->
      <form id="form-email" class="signin-form" novalidate>
        <div class="field">
          <label for="email" class="field-label">Correo electrónico</label>
          <input
            type="email"
            id="email"
            name="email"
            class="field-input"
            placeholder="tu@correo.com"
            autocomplete="email"
            required
          />
        </div>
        <button type="submit" id="btn-send-code" class="btn-primary">
          <span id="send-label">Enviar código</span>
          <span id="send-spinner" class="btn-spinner" hidden aria-hidden="true"></span>
        </button>
      </form>

      <!-- Step 2: código OTP (oculto inicialmente) -->
      <form id="form-code" class="signin-form" style="display:none;" novalidate>
        <p id="code-hint" class="code-hint"></p>
        <div class="field">
          <label for="code" class="field-label">Código de 6 dígitos</label>
          <input
            type="text"
            id="code"
            name="code"
            class="field-input field-code"
            placeholder="123456"
            inputmode="numeric"
            pattern="[0-9]{6}"
            maxlength="6"
            autocomplete="one-time-code"
            required
          />
        </div>
        <button type="submit" id="btn-verify" class="btn-primary">
          <span id="verify-label">Ingresar</span>
          <span id="verify-spinner" class="btn-spinner" hidden aria-hidden="true"></span>
        </button>
        <button type="button" id="btn-back" class="btn-ghost">← Cambiar correo</button>
      </form>

      <!-- Error inline -->
      <p id="signin-error" class="signin-error" hidden role="alert"></p>

      <p class="signin-note">
        Solo acceso por invitación.
        <a href="/comunidad/no-autorizado" class="signin-note-link">¿No tienes cuenta?</a>
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .signin-page {
    min-height: calc(100vh - 3.5rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: radial-gradient(
      ellipse 60% 40% at 50% -10%,
      color-mix(in srgb, var(--color-accent) 10%, transparent),
      transparent
    );
  }

  .signin-card {
    width: 100%;
    max-width: 22rem;
    padding: 2.5rem 2rem;
    background: var(--sf);
    border: 1px solid var(--bd);
    border-radius: 1.25rem;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .signin-brand { margin-bottom: 1.25rem; }

  .brand-logo {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    color: var(--tx);
  }

  .brand-dot { color: var(--color-accent); }

  .signin-title {
    margin: 0 0 0.5rem;
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--tx);
    letter-spacing: -0.02em;
  }

  .signin-subtitle {
    margin: 0 0 1.75rem;
    font-size: 0.875rem;
    color: var(--tx-muted);
    line-height: 1.55;
  }

  .signin-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-align: left;
  }

  .field-label {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--tx);
  }

  .field-input {
    padding: 0.65rem 0.75rem;
    border: 1.5px solid var(--bd);
    border-radius: 0.5rem;
    background: var(--sf2);
    color: var(--tx);
    font-size: 0.925rem;
    font-family: inherit;
    transition: border-color 0.15s;
    width: 100%;
    box-sizing: border-box;
  }

  .field-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 15%, transparent);
  }

  .field-code {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.4em;
    text-align: center;
  }

  .code-hint {
    margin: 0;
    font-size: 0.8rem;
    color: var(--tx-muted);
    text-align: left;
    line-height: 1.5;
  }

  .btn-primary {
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: 0.625rem;
    font-size: 0.925rem;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .btn-primary:hover:not(:disabled) { opacity: 0.9; }
  .btn-primary:disabled { opacity: 0.55; cursor: not-allowed; }

  .btn-ghost {
    width: 100%;
    padding: 0.5rem;
    background: transparent;
    border: none;
    color: var(--tx-muted);
    font-size: 0.8rem;
    font-family: inherit;
    cursor: pointer;
    text-align: center;
    transition: color 0.15s;
  }

  .btn-ghost:hover { color: var(--tx); }

  .btn-spinner {
    width: 1rem;
    height: 1rem;
    border: 2px solid rgba(255,255,255,0.35);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    flex-shrink: 0;
  }

  @keyframes spin { to { rotate: 360deg; } }

  .signin-error {
    width: 100%;
    margin-top: 0.5rem;
    padding: 0.6rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: #DC2626;
    background: color-mix(in srgb, #DC2626 10%, var(--sf));
    border: 1px solid color-mix(in srgb, #DC2626 25%, transparent);
    text-align: left;
  }

  .signin-note {
    margin-top: 1.5rem;
    font-size: 0.78rem;
    color: var(--tx-muted);
    line-height: 1.6;
  }

  .signin-note-link {
    display: block;
    margin-top: 0.15rem;
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .signin-note-link:hover { text-decoration: underline; }
</style>

<script is:inline>
  // --- helpers ---
  const formEmail = document.getElementById('form-email')
  const formCode  = document.getElementById('form-code')
  const emailInput  = document.getElementById('email')
  const codeInput   = document.getElementById('code')
  const codeHint    = document.getElementById('code-hint')
  const errorEl     = document.getElementById('signin-error')
  const btnSend     = document.getElementById('btn-send-code')
  const sendLabel   = document.getElementById('send-label')
  const sendSpinner = document.getElementById('send-spinner')
  const btnVerify     = document.getElementById('btn-verify')
  const verifyLabel   = document.getElementById('verify-label')
  const verifySpinner = document.getElementById('verify-spinner')
  const btnBack = document.getElementById('btn-back')

  // Estado compartido entre pasos
  var signInAttempt = null

  function showError(msg) {
    if (!errorEl) return
    errorEl.textContent = msg
    errorEl.hidden = false
  }

  function clearError() {
    if (errorEl) errorEl.hidden = true
  }

  function setLoading(btn, labelEl, spinnerEl, loading, defaultText) {
    btn.disabled = loading
    labelEl.textContent = loading ? 'Un momento...' : defaultText
    spinnerEl.hidden = !loading
  }

  function getClerkReady(cb) {
    var clerk = window.Clerk
    if (clerk && clerk.loaded) { cb(clerk); return }
    if (clerk) {
      var unsub = clerk.addListener(function(state) {
        if (state.client) { unsub(); cb(window.Clerk) }
      })
      return
    }
    document.addEventListener('clerk:loaded', function() { cb(window.Clerk) }, { once: true })
  }

  // --- Step 1: enviar código ---
  formEmail && formEmail.addEventListener('submit', function(e) {
    e.preventDefault()
    clearError()
    var email = emailInput.value.trim()
    if (!email) { showError('Ingresa tu correo.'); return }

    setLoading(btnSend, sendLabel, sendSpinner, true, 'Enviar código')

    getClerkReady(function(clerk) {
      clerk.client.signIn.create({ identifier: email })
        .then(function(attempt) {
          signInAttempt = attempt
          return attempt.prepareFirstFactor({ strategy: 'email_code' })
        })
        .then(function() {
          // Mostrar step 2
          formEmail.style.display = 'none'
          formCode.style.display = 'flex'
          if (codeHint) codeHint.textContent = 'Enviamos un código de 6 dígitos a ' + emailInput.value.trim() + '. Revisa tu bandeja.'
          if (codeInput) codeInput.focus()
          setLoading(btnSend, sendLabel, sendSpinner, false, 'Enviar código')
        })
        .catch(function(err) {
          setLoading(btnSend, sendLabel, sendSpinner, false, 'Enviar código')
          var msg = (err && err.errors && err.errors[0])
            ? (err.errors[0].longMessage || err.errors[0].message)
            : 'No pudimos verificar ese correo. ¿Fue invitado con esta dirección?'
          showError(msg)
        })
    })
  })

  // --- Step 2: verificar código ---
  formCode && formCode.addEventListener('submit', function(e) {
    e.preventDefault()
    clearError()
    var code = codeInput.value.replace(/\s/g, '')
    if (code.length !== 6) { showError('Ingresa el código de 6 dígitos.'); return }

    setLoading(btnVerify, verifyLabel, verifySpinner, true, 'Ingresar')

    if (!signInAttempt) {
      showError('Sesión expirada. Vuelve a ingresar tu correo.')
      setLoading(btnVerify, verifyLabel, verifySpinner, false, 'Ingresar')
      return
    }

    signInAttempt.attemptFirstFactor({ strategy: 'email_code', code: code })
      .then(function(result) {
        if (result.status === 'complete') {
          // Setear sesión activa y redirigir
          window.Clerk.setActive({ session: result.createdSessionId })
            .then(function() { window.location.href = '/comunidad' })
        } else {
          // Estado intermedio inesperado
          setLoading(btnVerify, verifyLabel, verifySpinner, false, 'Ingresar')
          showError('Verificación incompleta. Código: ' + result.status)
        }
      })
      .catch(function(err) {
        setLoading(btnVerify, verifyLabel, verifySpinner, false, 'Ingresar')
        var msg = (err && err.errors && err.errors[0])
          ? (err.errors[0].longMessage || err.errors[0].message)
          : 'Código incorrecto o expirado. Inténtalo de nuevo.'
        showError(msg)
      })
  })

  // --- Volver al step 1 ---
  btnBack && btnBack.addEventListener('click', function() {
    clearError()
    signInAttempt = null
    formCode.style.display = 'none'
    formEmail.style.display = 'flex'
    if (codeInput) codeInput.value = ''
    if (emailInput) emailInput.focus()
  })
</script>
