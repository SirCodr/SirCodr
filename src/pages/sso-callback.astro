---
import { AuthenticateWithRedirectCallback } from '@clerk/astro/components'
// Esta página completa el handshake OAuth con Google y redirige al usuario.
// No debe tener layout ni contenido visible.
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Conectando...</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0f0f0f;
        color: #f0f0f0;
        font-family: system-ui, sans-serif;
        font-size: 0.9rem;
      }
    </style>
  </head>
  <body>
    <p>Verificando credenciales...</p>
    <AuthenticateWithRedirectCallback
      afterSignInUrl="/comunidad"
      afterSignUpUrl="/comunidad/no-autorizado"
    />
  </body>
</html>
